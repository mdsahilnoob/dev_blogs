---
interface CountItem {
  name: string;
  count: number;
}

interface Props {
  categories?: CountItem[];
  sources?: CountItem[];
}

const {
  categories = [],
  sources = [],
} = Astro.props;

const docsSections = ["Introduction", "Components", "Installation", "Theming", "CLI", "Forms", "Changelog"];
---

<aside class="blog-sidebar" aria-label="Blog sidebar">
  <div class="sidebar-shell">
    <div class="sidebar-header">
      <p class="sidebar-brand">Docs</p>
      <a class="sidebar-create" href="/blog">Create</a>
    </div>

    <label class="sidebar-search-wrap" for="sidebar-search">
      <span class="sr-only">Search sidebar content</span>
      <input id="sidebar-search" type="search" placeholder="Search..." class="sidebar-search" autocomplete="off" />
    </label>

    <div class="sidebar-content">
      <section class="sidebar-group" aria-labelledby="sidebar-sections-label">
        <p class="sidebar-group-label" id="sidebar-sections-label">Sections</p>
        <ul class="sidebar-menu">
          {docsSections.map((item) => (
            <li><a class="sidebar-link" href="/blog">{item}</a></li>
          ))}
        </ul>
      </section>

      <section class="sidebar-group" aria-labelledby="sidebar-categories-label">
        <p class="sidebar-group-label" id="sidebar-categories-label">Categories</p>
        <ul class="sidebar-menu">
          {categories.length === 0 ? (
            <li><span class="sidebar-link">No categories yet</span></li>
          ) : (
            categories.map((item) => (
              <li>
                <a class="sidebar-link" href={`/blog/?category=${encodeURIComponent(item.name)}`}>
                  {item.name} ({item.count})
                </a>
              </li>
            ))
          )}
        </ul>
      </section>

      <section class="sidebar-group" aria-labelledby="sidebar-sources-label">
        <p class="sidebar-group-label" id="sidebar-sources-label">Top Engineering Blogs</p>
        <ul class="sidebar-menu">
          {sources.length === 0 ? (
            <li><span class="sidebar-link">No sources yet</span></li>
          ) : (
            sources.map((item) => (
              <li>
                <a class="sidebar-link" href={`/blog/?source=${encodeURIComponent(item.name)}`}>
                  {item.name} ({item.count})
                </a>
              </li>
            ))
          )}
        </ul>
      </section>
    </div>

    <div class="sidebar-footer">
      <p class="meta-chip">109k users</p>
      <button class="sidebar-theme" type="button" disabled aria-disabled="true" title="Theme toggle is not available yet">
        Theme Soon
      </button>
    </div>
  </div>
</aside>
