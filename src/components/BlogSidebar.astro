---
interface CountItem {
  name: string;
  count: number;
}

interface Props {
  categories?: CountItem[];
  searchQuery?: string;
  selectedCategory?: string | null;
  selectedSource?: string | null;
}

const {
  categories = [],
  searchQuery = "",
  selectedCategory = null,
  selectedSource = null,
} = Astro.props;
---

<aside class="blog-sidebar" aria-label="Blog sidebar">
  <div class="sidebar-shell">
    <div class="sidebar-header">
      <a class="sidebar-brand" href="/home">DevWire</a>
      <a class="sidebar-create" href="/home">Browse</a>
    </div>

    <form class="sidebar-search-wrap" method="get" action="/blog">
      <label class="sr-only" for="sidebar-search">Search reports</label>
      <input
        id="sidebar-search"
        name="q"
        type="search"
        value={searchQuery}
        placeholder="Search reports..."
        class="sidebar-search"
        autocomplete="off"
      />
      <button class="sidebar-search-btn" type="submit">Search</button>
      {selectedCategory && <input type="hidden" name="category" value={selectedCategory} />}
      {selectedSource && <input type="hidden" name="source" value={selectedSource} />}
    </form>

    <div class="sidebar-content">
      <section class="sidebar-group" aria-labelledby="sidebar-categories-label">
        <p class="sidebar-group-label" id="sidebar-categories-label">Categories</p>
        <ul class="sidebar-menu">
          {categories.length === 0 ? (
            <li><span class="sidebar-link">No categories available</span></li>
          ) : (
            categories.map((item) => (
              <li>
                <a class="sidebar-link" href={`/blog/?category=${encodeURIComponent(item.name)}`}>
                  {item.name} ({item.count})
                </a>
              </li>
            ))
          )}
        </ul>
      </section>

    </div>

    <div class="sidebar-footer">
      <p class="meta-chip">109k users</p>
      <button class="sidebar-theme" type="button" data-theme-toggle aria-label="Toggle dark mode">
        Dark Mode
      </button>
    </div>
  </div>
</aside>

<script>
  (() => {
    const root = document.documentElement;
    const toggles = Array.from(document.querySelectorAll("[data-theme-toggle]"));

    const currentTheme = () => root.dataset.theme === "dark" ? "dark" : "light";

    const syncToggleLabels = () => {
      const isDark = currentTheme() === "dark";
      toggles.forEach((btn) => {
        btn.textContent = isDark ? "Light Mode" : "Dark Mode";
        btn.setAttribute("aria-pressed", isDark ? "true" : "false");
      });
    };

    const setTheme = (theme) => {
      root.dataset.theme = theme;
      localStorage.setItem("theme", theme);
      syncToggleLabels();
    };

    syncToggleLabels();

    toggles.forEach((btn) => {
      btn.addEventListener("click", () => {
        setTheme(currentTheme() === "dark" ? "light" : "dark");
      });
    });
  })();
</script>
