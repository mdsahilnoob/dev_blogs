---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";

const tickerItems = [
  "Q2 SaaS retention benchmarks released",
  "AI copilots now in 71% of product teams",
  "Cloud cost discipline drives new buying behavior",
  "Founder briefing: shipping velocity vs reliability",
];
---

<header class="news-header">
  <a class="skip-link" href="#main-content">Skip To Content</a>
  <div class="ticker" aria-label="Breaking news" aria-live="off">
    <div class="ticker-track">
      {tickerItems.concat(tickerItems).map((item) => (
        <span>{item}</span>
      ))}
    </div>
  </div>

  <div class="container">
    <nav class="masthead" aria-label="Primary navigation">
      <a href="/" class="logo">{SITE_TITLE}</a>
      <div class="main-nav">
        <HeaderLink href="/">Latest</HeaderLink>
        <HeaderLink href="/blog">Reports</HeaderLink>
        <HeaderLink href="/about">Editorial</HeaderLink>
      </div>
      <a class="news-btn" href="/#premium">Join Premium</a>
    </nav>
  </div>
</header>
