---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";

const tickerItems = [
  "New: Cloudflare, GitHub, and Meta engineering updates are live",
  "Weekly deep dive: AI adoption tradeoffs in product teams",
  "SaaS pricing signal report updated with March benchmarks",
  "Operator brief: delivery speed versus production reliability",
];
---

<header class="news-header">
  <a class="skip-link" href="#main-content">Skip To Content</a>
  <div class="ticker" aria-label="Breaking news" aria-live="off">
    <div class="ticker-track">
      {tickerItems.concat(tickerItems).map((item) => (
        <span>{item}</span>
      ))}
    </div>
  </div>

  <div class="container">
    <nav class="masthead" aria-label="Primary navigation">
      <a href="/" class="logo">{SITE_TITLE}</a>
      <div class="main-nav">
        <HeaderLink href="/">Home</HeaderLink>
        <HeaderLink href="/blog">Engineering Reports</HeaderLink>
        <HeaderLink href="/about">About</HeaderLink>
      </div>
      <a class="news-btn" href="/#premium">Subscribe</a>
    </nav>
  </div>
</header>
