---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";

const tickerItems = [
  "New: Cloudflare, GitHub, and Meta engineering updates are live",
  "Weekly deep dive: AI adoption tradeoffs in product teams",
  "SaaS pricing signal report updated with March benchmarks",
  "Operator brief: delivery speed versus production reliability",
];
---

<header class="news-header">
  <a class="skip-link" href="#main-content">Skip To Content</a>
  <div class="ticker" aria-label="Breaking news" aria-live="off">
    <div class="ticker-track">
      {tickerItems.concat(tickerItems).map((item) => (
        <span>{item}</span>
      ))}
    </div>
  </div>

  <div class="container">
    <nav class="masthead" aria-label="Primary navigation">
      <a href="/" class="logo">{SITE_TITLE}</a>
      <div class="main-nav">
        <HeaderLink href="/">Home</HeaderLink>
        <HeaderLink href="/blog">Engineering Reports</HeaderLink>
        <HeaderLink href="/about">About</HeaderLink>
        <button class="theme-toggle-btn" type="button" data-theme-toggle aria-label="Toggle dark mode">
          Dark Mode
        </button>
      </div>
      <a class="news-btn" href="/#premium">Subscribe</a>
    </nav>
  </div>
</header>

<script>
  (() => {
    const root = document.documentElement;
    const toggles = Array.from(document.querySelectorAll("[data-theme-toggle]"));

    const currentTheme = () => root.dataset.theme === "dark" ? "dark" : "light";

    const syncToggleLabels = () => {
      const isDark = currentTheme() === "dark";
      toggles.forEach((btn) => {
        btn.textContent = isDark ? "Light Mode" : "Dark Mode";
        btn.setAttribute("aria-pressed", isDark ? "true" : "false");
      });
    };

    const setTheme = (theme) => {
      root.dataset.theme = theme;
      localStorage.setItem("theme", theme);
      syncToggleLabels();
    };

    syncToggleLabels();

    toggles.forEach((btn) => {
      btn.addEventListener("click", () => {
        setTheme(currentTheme() === "dark" ? "light" : "dark");
      });
    });
  })();
</script>
