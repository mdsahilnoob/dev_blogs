---
export const prerender = false;

import { getCollection, type CollectionEntry } from "astro:content";
import { hc } from "hono/client";

import BaseHead from "../components/BaseHead.astro";
import BlogCard from "../components/BlogCard.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import NewsCard from "../components/NewsCard.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import type { AppType } from "../lib/server/api";

interface NewsItem {
  id: number;
  title: string;
  sourceUrl: string;
  contentSummary: string;
  category: string;
  publishedAt: string;
}

type MixedItem =
  | {
      kind: "news";
      value: NewsItem;
    }
  | {
      kind: "blog";
      value: CollectionEntry<"blog">;
    };

const latestBlogs = (await getCollection("blog"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const rpcClient = hc<AppType>(new URL("/api", Astro.url).toString()) as {
  news: {
    $get: (args: {
      query: { page: string; pageSize: string; category?: string };
    }) => Promise<Response>;
  };
};
let topNews: NewsItem[] = [];
let newsError: string | null = null;

try {
  const response = await rpcClient.news.$get({
    query: {
      page: "1",
      pageSize: "5",
    },
  });

  if (!response.ok) {
    newsError = `News API returned status ${response.status}.`;
  } else {
    const payload = (await response.json()) as { data: NewsItem[] };
    topNews = payload.data;
  }
} catch {
  newsError = "Unable to reach the news API during this request.";
}

const mixedItems: MixedItem[] = [];
const totalSlots = Math.max(topNews.length, latestBlogs.length);

for (let i = 0; i < totalSlots; i += 1) {
  if (topNews[i]) {
    mixedItems.push({ kind: "news", value: topNews[i] });
  }

  if (latestBlogs[i]) {
    mixedItems.push({ kind: "blog", value: latestBlogs[i] });
  }
}

const homeJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE_TITLE,
    description: SITE_DESCRIPTION,
    url: new URL("/", Astro.url).toString(),
  },
  ...topNews.map((item) => ({
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    headline: item.title,
    description: item.contentSummary,
    url: item.sourceUrl,
    mainEntityOfPage: item.sourceUrl,
    datePublished: item.publishedAt,
  })),
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={SITE_TITLE}
      description={SITE_DESCRIPTION}
      jsonLd={homeJsonLd}
    />
  </head>
  <body>
    <Header />
    <main class="mx-auto w-full max-w-6xl px-4 pb-16 pt-8 md:px-6">
      <section
        class="mb-8 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm md:p-8"
      >
        <p
          class="mb-3 inline-flex rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-600"
        >
          Edge-ready stack · Astro + Hono + D1
        </p>
        <h1
          class="text-3xl font-semibold tracking-tight text-slate-900 md:text-5xl"
        >
          Tech News and Developer Blogs, optimized for speed.
        </h1>
        <p
          class="mt-4 max-w-3xl text-base leading-relaxed text-slate-600 md:text-lg"
        >
          Read curated engineering headlines and deep technical posts from one
          edge-first experience. The feed is rendered server-side for search
          visibility and paired with static Astro content for excellent Core Web
          Vitals.
        </p>

        <form
          class="mt-6 flex flex-col gap-3 sm:flex-row"
          method="post"
          action="/api/newsletter"
        >
          <label class="sr-only" for="newsletter-email">Email address</label>
          <input
            id="newsletter-email"
            name="email"
            type="email"
            required
            placeholder="your@email.dev"
            class="h-11 w-full rounded-xl border border-slate-300 bg-white px-4 text-sm text-slate-900 outline-none transition focus:border-slate-500"
          />
          <button
            type="submit"
            class="h-11 rounded-xl bg-slate-900 px-5 text-sm font-medium text-white transition hover:bg-slate-800"
          >
            Subscribe to newsletter
          </button>
        </form>

        {newsError && <p class="mt-3 text-sm text-amber-700">{newsError}</p>}
      </section>

      <section aria-label="Mixed bento feed of news and blogs">
        {
          mixedItems.length === 0 ? (
            <p class="rounded-2xl border border-slate-200 bg-white p-6 text-sm text-slate-600">
              No content is available yet. Add rows to D1 news or publish more
              blog posts to populate the feed.
            </p>
          ) : (
            <div class="grid gap-4 md:auto-rows-[minmax(220px,1fr)] md:grid-cols-4">
              {mixedItems.map((item, index) => (
                <div
                  class:list={[
                    index === 0
                      ? "md:col-span-2 md:row-span-2"
                      : index % 5 === 0
                        ? "md:col-span-2"
                        : "md:col-span-1",
                  ]}
                >
                  {item.kind === "news" ? (
                    <NewsCard item={item.value} featured={index === 0} />
                  ) : (
                    <BlogCard entry={item.value} featured={index === 0} />
                  )}
                </div>
              ))}
            </div>
          )
        }
      </section>
    </main>
    <Footer />
  </body>
</html>
