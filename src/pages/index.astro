---
export const prerender = false;

import { Image } from "astro:assets";
import { getCollection } from "astro:content";

import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

import image1 from "../assets/blog-placeholder-1.jpg";
import image2 from "../assets/blog-placeholder-2.jpg";
import image3 from "../assets/blog-placeholder-3.jpg";
import image4 from "../assets/blog-placeholder-4.jpg";
import image5 from "../assets/blog-placeholder-5.jpg";

const featuredBlogs = (await getCollection("blog"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const testimonials = [
  {
    quote: "The strongest SaaS publication for strategic product context.",
    name: "Mina Patel",
    role: "Product Lead",
  },
  {
    quote: "Dense, practical, and always useful in roadmap review meetings.",
    name: "Jonas Weber",
    role: "Growth Engineer",
  },
  {
    quote: "Feels like an analyst report, not a content farm article.",
    name: "Asha Raman",
    role: "Founder",
  },
];

const homeJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE_TITLE,
  description: SITE_DESCRIPTION,
  url: new URL("/", Astro.url).toString(),
};

const mosaicImages = [image1, image2, image3, image4, image5, image1, image3, image4, image2];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} jsonLd={homeJsonLd} />
  </head>
  <body>
    <Header />

    <main>
      <div class="container">
        <section class="sheet">
          <div class="news-grid">
            <article class="hero-feature">
              <p class="hero-kicker">Exclusive Coverage • {new Date().toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</p>
              <h1 class="hero-title">The Final Product Judgment</h1>
              <p class="hero-sub">
                In-depth analysis of SaaS platform shifts, pricing pressure, AI tooling adoption, and what this quarter means for teams planning the next release cycle.
              </p>
              <div class="hero-actions">
                <a href="/blog" class="btn-primary">Read Full Dossier</a>
                <a href="#premium" class="btn-ghost">Unlock Premium</a>
              </div>
            </article>

            <aside class="mosaic" aria-label="Editorial snapshots">
              {mosaicImages.map((img) => (
                <Image src={img} width={320} height={220} alt="Editorial collage image" loading="lazy" />
              ))}
            </aside>
          </div>

          <section id="features" class="news-cards">
            <article class="news-card">
              <p class="card-meta">Meta Alert</p>
              <h3>Platform Cost vs AI Velocity</h3>
              <p>We benchmark how leading SaaS teams trade reliability, inference costs, and time-to-market in 2026.</p>
              <a class="post-link" href="/blog">Reading Time: 12 Min</a>
            </article>
            <article class="news-card">
              <p class="card-meta">Event Guide</p>
              <h3>How To Run Weekly Execution Reviews</h3>
              <p>Templates and rituals for turning noisy metrics into one-page decisions your team can execute quickly.</p>
              <a class="post-link" href="/blog">Reading Time: 7 Min</a>
            </article>
            <article class="news-card">
              <p class="card-meta">Leak Watch</p>
              <h3>What Buyers Expect In New SaaS Plans</h3>
              <p>Signals from pricing-page experiments and enterprise procurement behavior across growth-stage products.</p>
              <a class="post-link" href="/blog">Reading Time: 9 Min</a>
            </article>
          </section>
        </section>

        <section class="dark-band" id="testimonials">
          <p class="section-kicker" style="color:#bbbbbb;">Testimonials</p>
          <h2 class="hero-title">The Art Of SaaS Briefing</h2>
          <div class="dark-grid">
            {testimonials.map((item) => (
              <article class="dark-card">
                <h4>{item.name}</h4>
                <p>{item.quote}</p>
                <p class="meta-chip" style="color:#a5a5a5;">{item.role}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="spotlight" id="blogs">
          <p class="section-kicker">Current Briefings</p>
          <h2 class="spotlight-title">Character Spotlight</h2>
          {
            featuredBlogs.length === 0 ? (
              <p class="news-card">No reports published yet.</p>
            ) : (
              <div class="char-grid">
                {featuredBlogs.slice(0, 3).map((entry, idx) => (
                  <article class="char-card">
                    <Image
                      src={entry.data.heroImage ?? mosaicImages[idx]}
                      width={640}
                      height={420}
                      alt={`Cover image for ${entry.data.title}`}
                      loading="lazy"
                    />
                    <div class="body">
                      <p class="card-meta">{(entry.data.category ?? "Engineering").toUpperCase()}</p>
                      <h3 class="post-title">{entry.data.title}</h3>
                      <p>{entry.data.description}</p>
                      <a class="post-link" href={`/blog/${entry.id}/`}>View Detailed Build</a>
                    </div>
                  </article>
                ))}
              </div>
            )
          }
        </section>

        <section class="stat-row">
          <article class="stat-cell">
            <p class="stat-number">250k+</p>
            <p class="meta-chip">Monthly readers across product, growth, and engineering teams.</p>
          </article>
          <article class="stat-cell">
            <p class="stat-number">1.2k</p>
            <p class="meta-chip">Comments and reactions on weekly briefings.</p>
          </article>
          <article class="stat-cell">
            <p class="stat-number">100%</p>
            <p class="meta-chip">Operator-focused, hype-free editorial policy.</p>
          </article>
        </section>

        <section class="subscribe-box" id="premium">
          <div>
            <h3>Subscribe To The Daily DevWire</h3>
            <p style="margin:8px 0 0;">Exclusive reports, early market data, and premium deep-dives.</p>
          </div>
          <form method="post" action="/api/newsletter">
            <label class="sr-only" for="newsletter-email">Email address</label>
            <input id="newsletter-email" name="email" type="email" required placeholder="you@company.com" />
            <button type="submit">Join Premium</button>
          </form>
        </section>
      </div>
    </main>

    <Footer />
  </body>
</html>
