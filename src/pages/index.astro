---
export const prerender = false;

import { Image } from "astro:assets";

import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { getCategorizedEngineeringNews } from "../lib/server/engineering-news";

import image1 from "../assets/blog-placeholder-1.jpg";
import image2 from "../assets/blog-placeholder-2.jpg";
import image3 from "../assets/blog-placeholder-3.jpg";
import image4 from "../assets/blog-placeholder-4.jpg";
import image5 from "../assets/blog-placeholder-5.jpg";

const feedData = await getCategorizedEngineeringNews(30);
const featuredBlogs = feedData.items.slice(0, 3);

const testimonials = [
  {
    quote: "The strongest SaaS publication for strategic product context.",
    name: "Mina Patel",
    role: "Product Lead",
  },
  {
    quote: "Dense, practical, and always useful in roadmap review meetings.",
    name: "Jonas Weber",
    role: "Growth Engineer",
  },
  {
    quote: "Feels like an analyst report, not a content farm article.",
    name: "Asha Raman",
    role: "Founder",
  },
];

const homeJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE_TITLE,
  description: SITE_DESCRIPTION,
  url: new URL("/", Astro.url).toString(),
};

const mosaicImages = [image1, image2, image3, image4, image5, image1, image3, image4, image2];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} jsonLd={homeJsonLd} />
  </head>
  <body>
    <Header />

    <main id="main-content">
      <div class="container">
        <section class="sheet">
          <div class="news-grid">
            <article class="hero-feature">
              <p class="hero-kicker">Editor&apos;s Brief • {new Date().toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</p>
              <h1 class="hero-title">Engineering News For Teams That Ship</h1>
              <p class="hero-sub">
                Daily reporting on architecture, AI tooling, platform reliability, and product execution from leading engineering organizations.
              </p>
              <div class="hero-actions">
                <a href="/blog" class="btn-primary" aria-label="Browse all engineering reports">Read Latest Reports</a>
                <a href="#premium" class="btn-ghost" aria-label="Jump to newsletter subscription">Get Daily Brief</a>
              </div>
            </article>

            <aside class="mosaic" aria-label="Editorial snapshots">
              {mosaicImages.map((img) => (
                <Image src={img} width={320} height={220} alt="" loading="lazy" aria-hidden="true" />
              ))}
            </aside>
          </div>

          <section id="features" class="news-cards" aria-labelledby="featured-analyses-title">
            <h2 id="featured-analyses-title" class="sr-only">Featured analyses</h2>
            <article class="news-card">
              <p class="card-meta">Editorial Analysis</p>
              <h3>Platform Cost vs. AI Delivery Speed</h3>
              <p>How engineering leaders balance inference cost, latency, and release cadence across modern SaaS stacks.</p>
              <a class="post-link" href="/blog" aria-label="Read analysis on platform cost and AI delivery speed">Read Analysis</a>
            </article>
            <article class="news-card">
              <p class="card-meta">Execution Guide</p>
              <h3>How High-Performing Teams Run Weekly Reviews</h3>
              <p>A practical briefing for turning dashboards into decisions, owners, and measurable follow-through.</p>
              <a class="post-link" href="/blog" aria-label="Read guide on engineering execution reviews">Read Guide</a>
            </article>
            <article class="news-card">
              <p class="card-meta">Market Signal</p>
              <h3>What Enterprise Buyers Now Expect From SaaS Plans</h3>
              <p>Patterns from packaging tests, procurement conversations, and renewal behavior in 2026.</p>
              <a class="post-link" href="/blog" aria-label="Read market signal report on SaaS buyer expectations">Read Report</a>
            </article>
          </section>
        </section>

        <section class="dark-band" id="testimonials" aria-labelledby="reader-feedback-title">
          <p class="section-kicker" style="color:#bbbbbb;">Testimonials</p>
          <h2 id="reader-feedback-title" class="hero-title">Trusted By Product And Engineering Leaders</h2>
          <div class="dark-grid">
            {testimonials.map((item) => (
              <article class="dark-card">
                <h4>{item.name}</h4>
                <p>{item.quote}</p>
                <p class="meta-chip" style="color:#a5a5a5;">{item.role}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="spotlight" id="blogs" aria-labelledby="latest-briefings-title">
          <p class="section-kicker">Current Briefings</p>
          <h2 id="latest-briefings-title" class="spotlight-title">Latest Engineering Blogs</h2>
          {
            featuredBlogs.length === 0 ? (
              <p class="news-card">No reports published yet.</p>
            ) : (
              <div class="char-grid">
                {featuredBlogs.map((entry, idx) => (
                  <article class="char-card">
                    <Image
                      src={mosaicImages[idx]}
                      width={640}
                      height={420}
                      alt=""
                      aria-hidden="true"
                      loading="lazy"
                    />
                    <div class="body">
                      <p class="card-meta">
                        {entry.category.toUpperCase()} | {entry.sourceName.toUpperCase()} | {entry.readingTimeMinutes} MIN READ
                      </p>
                      <h3 class="post-title">{entry.title}</h3>
                      <p>{entry.contentSummary}</p>
                      <a
                        class="post-link"
                        href={entry.sourceUrl}
                        target="_blank"
                        rel="noreferrer"
                        aria-label={`Read original post: ${entry.title}`}
                      >
                        Read Original
                      </a>
                    </div>
                  </article>
                ))}
              </div>
            )
          }
        </section>

        <section class="stat-row">
          <article class="stat-cell">
            <p class="stat-number">250k+</p>
            <p class="meta-chip">Monthly readers across product, growth, and engineering teams.</p>
          </article>
          <article class="stat-cell">
            <p class="stat-number">1.2k</p>
            <p class="meta-chip">Comments and reactions on weekly briefings.</p>
          </article>
          <article class="stat-cell">
            <p class="stat-number">100%</p>
            <p class="meta-chip">Operator-focused, hype-free editorial policy.</p>
          </article>
        </section>

        <section class="subscribe-box" id="premium">
          <div>
            <h3>Subscribe To The Daily Engineering Brief</h3>
            <p id="newsletter-help" style="margin:8px 0 0;">One concise email each weekday with the top engineering stories and analysis.</p>
          </div>
          <form method="post" action="/api/newsletter">
            <label class="sr-only" for="newsletter-email">Email address</label>
            <input id="newsletter-email" name="email" type="email" required placeholder="you@company.com" autocomplete="email" aria-describedby="newsletter-help" />
            <button type="submit">Subscribe</button>
          </form>
        </section>
      </div>
    </main>

    <Footer />
  </body>
</html>
