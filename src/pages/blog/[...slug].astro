---
export const prerender = false;

import { env } from "cloudflare:workers";
import { and, eq } from "drizzle-orm";

import BlogPost from "../../layouts/BlogPost.astro";
import type { ApiBindings } from "../../lib/server/db/client";
import { getDb } from "../../lib/server/db/client";
import { blogs } from "../../lib/server/db/schema";

const slug = (Astro.params.slug ?? "").trim();

if (!slug) {
  return Astro.redirect("/blog");
}

const db = getDb(env as Partial<ApiBindings>);

if (!db) {
  return new Response("Database not available", { status: 503 });
}

const [post] = await db
  .select({
    slug: blogs.slug,
    title: blogs.title,
    description: blogs.description,
    category: blogs.category,
    tags: blogs.tags,
    publishedAt: blogs.publishedAt,
    updatedAt: blogs.updatedAt,
  })
  .from(blogs)
  .where(and(eq(blogs.slug, slug), eq(blogs.isPublished, true)))
  .limit(1);

if (!post) {
  return new Response("Not found", { status: 404 });
}
---

<BlogPost
  title={post.title}
  description={post.description}
  pubDate={post.publishedAt}
  updatedDate={post.updatedAt ?? undefined}
  category={post.category}
  tags={Array.isArray(post.tags) ? post.tags : []}
>
  <p>{post.description}</p>
  <p>
    This report is served from the DevWire D1 database. Extended article body support can be added by
    storing full markdown/HTML content in the database.
  </p>
</BlogPost>
