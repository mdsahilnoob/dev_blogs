---
export const prerender = false;

import { env } from "cloudflare:workers";
import { desc, eq } from "drizzle-orm";

import BaseHead from "../../components/BaseHead.astro";
import BlogSidebar from "../../components/BlogSidebar.astro";
import Footer from "../../components/Footer.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import type { ApiBindings } from "../../lib/server/db/client";
import { getDb } from "../../lib/server/db/client";
import { FALLBACK_BLOGS } from "../../lib/server/fallback-blogs";
import { blogs, news } from "../../lib/server/db/schema";

const selectedCategory = Astro.url.searchParams.get("category")?.trim() || null;
const selectedSource = Astro.url.searchParams.get("source")?.trim() || null;
const searchQuery = Astro.url.searchParams.get("q")?.trim() || null;

const db = getDb(env as Partial<ApiBindings>);

const allNews = db
  ? await db
      .select({
        title: news.title,
        sourceUrl: news.sourceUrl,
        sourceName: news.sourceName,
        author: news.author,
        contentSummary: news.contentSummary,
        category: news.category,
        publishedAt: news.publishedAt,
        readingTimeMinutes: news.readingTimeMinutes,
      })
      .from(news)
      .orderBy(desc(news.publishedAt))
      .limit(300)
  : [];

const categoryCounts = allNews.reduce<Record<string, number>>((acc, item) => {
  acc[item.category] = (acc[item.category] ?? 0) + 1;
  return acc;
}, {});

const sourceCounts = allNews.reduce<Record<string, number>>((acc, item) => {
  acc[item.sourceName] = (acc[item.sourceName] ?? 0) + 1;
  return acc;
}, {});

const feedData = {
  categories: Object.entries(categoryCounts)
    .map(([name, count]) => ({ name, count }))
    .sort((a, b) => b.count - a.count),
  sources: Object.entries(sourceCounts)
    .map(([name, count]) => ({ name, count }))
    .sort((a, b) => b.count - a.count),
};

const externalPosts = allNews.filter((item) => {
  const categoryOk = !selectedCategory || item.category.toLowerCase() === selectedCategory.toLowerCase();
  const sourceOk = !selectedSource || item.sourceName.toLowerCase() === selectedSource.toLowerCase();
  const searchHaystack = `${item.title} ${item.contentSummary} ${item.sourceName} ${item.category}`.toLowerCase();
  const searchOk = !searchQuery || searchHaystack.includes(searchQuery.toLowerCase());
  return categoryOk && sourceOk && searchOk;
});
const allBlogs = db
  ? await db
      .select({
        slug: blogs.slug,
        title: blogs.title,
        description: blogs.description,
        content: blogs.content,
        category: blogs.category,
        publishedAt: blogs.publishedAt,
        tags: blogs.tags,
      })
      .from(blogs)
      .where(eq(blogs.isPublished, true))
      .orderBy(desc(blogs.publishedAt))
      .limit(60)
  : [];

const fallbackBlogs = FALLBACK_BLOGS.map((post) => ({
  ...post,
  content:
    `${post.title} is a strategic frontend topic with direct impact on reliability, delivery speed, and user trust. ` +
    `Teams that treat this as a repeatable engineering capability outperform teams that handle it as a one-off fix. ` +
    `A strong implementation starts with a clear baseline, then applies incremental rollout, testing discipline, and incident-ready observability. ` +
    `The objective is not only shipping a change, but reducing risk while preserving momentum across product and platform teams.\n\n` +
    `Execution should begin by defining measurable outcomes and explicit constraints. Capture current latency, error rates, and user-impacting regressions before implementation. ` +
    `Then map dependencies across API contracts, client state, and release pipelines. ` +
    `Use small pull requests, contract checks, and staged rollout so defects are contained early. ` +
    `During rollout, verify analytics, monitor key funnels, and keep rollback paths simple and documented. ` +
    `After release, run a short retrospective to consolidate lessons into standards and templates for future projects.\n\n` +
    `In practice, this topic intersects architecture, developer experience, and operational maturity. ` +
    `The most effective teams align on ownership, keep decision records lightweight but consistent, and prioritize maintainability in each iteration. ` +
    `That means naming conventions, test boundaries, and observability hooks are designed up front instead of patched late. ` +
    `When this pattern is sustained over multiple releases, teams gain predictable delivery and higher confidence under pressure.\n\n` +
    `For this report, start from: ${post.description} ` +
    `Translate that goal into acceptance criteria, rollout checkpoints, and post-launch metrics so the outcome is measurable. ` +
    `With this approach, you can scale execution across teams without sacrificing quality, and each release becomes a reliable step forward.`,
}));

const blogSource = allBlogs.length > 0 ? allBlogs : fallbackBlogs;

const localBlogs = blogSource.filter((post) => {
  const categoryOk = !selectedCategory || post.category.toLowerCase() === selectedCategory.toLowerCase();
  const searchHaystack = `${post.title} ${post.description} ${post.category} ${(post.tags ?? []).join(" ")} ${post.content}`.toLowerCase();
  const searchOk = !searchQuery || searchHaystack.includes(searchQuery.toLowerCase());
  return categoryOk && searchOk;
});

---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Reports | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <main id="main-content">
      <div class="blog-page-layout">
        <BlogSidebar
          categories={feedData.categories}
          searchQuery={searchQuery ?? ""}
          selectedCategory={selectedCategory}
          selectedSource={selectedSource}
        />

        <section class="blog-main">
          <section class="page-head">
            <p class="section-kicker">Engineering News Feed</p>
            <h1 class="page-title">Latest Engineering Reports</h1>
            <p class="page-sub">
              Curated daily updates from Netflix, Meta, LinkedIn, Uber, Airbnb, Discord, Cloudflare, and GitHub.
              Stories are grouped into Web Engineering, Cloud/DevOps, AI/ML, Security, Data Systems, and Infrastructure.
            </p>
            {
              (selectedCategory || selectedSource || searchQuery) && (
                <p class="card-meta" style="margin-top:10px;">
                  Active Filters:
                  {selectedCategory ? ` category=${selectedCategory}` : ""}
                  {selectedSource ? ` source=${selectedSource}` : ""}
                  {searchQuery ? ` q=${searchQuery}` : ""}
                  <a class="post-link" style="margin-left:8px;" href="/blog">Clear</a>
                </p>
              )
            }
          </section>

          <section class="post-grid">
            {
              externalPosts.length === 0 ? (
                <article class="post-card">
                  <div class="post-body">
                    <h2 class="post-title">No matching engineering posts found.</h2>
                    {
                      searchQuery && (
                        <p>
                          Try a different search for <strong>{searchQuery}</strong> or clear filters.
                        </p>
                      )
                    }
                  </div>
                </article>
              ) : (
                externalPosts.map((post) => (
                  <article class="post-card">
                    <div class="post-body">
                      <p class="card-meta">
                        {post.category.toUpperCase()} | {post.sourceName.toUpperCase()} | {post.readingTimeMinutes} MIN READ
                      </p>
                      <h2 class="post-title">{post.title}</h2>
                      <p>{post.contentSummary}</p>
                      <p class="meta-chip" style="display:block;margin-bottom:8px;">
                        {post.author ? `By ${post.author}` : "Author unavailable"} | {post.publishedAt.toLocaleDateString("en-US", {
                          month: "short",
                          day: "numeric",
                          year: "numeric",
                        })}
                      </p>
                      <a
                        class="post-link"
                        href={post.sourceUrl}
                        target="_blank"
                        rel="noreferrer"
                        aria-label={`Read original post from ${post.sourceName}: ${post.title}`}
                      >
                        Read Original
                      </a>
                    </div>
                  </article>
                ))
              )
            }
          </section>

          <section class="page-head" style="margin-top:12px;">
            <p class="section-kicker">Internal Editorial</p>
            <h2 class="page-title" style="font-size:clamp(28px,3vw,40px);">Original DevWire Reports</h2>
          </section>

          <section class="post-grid">
            {
              localBlogs.length === 0 ? (
                <article class="post-card">
                  <div class="post-body">
                    <h2 class="post-title">No matching DevWire reports found.</h2>
                  </div>
                </article>
              ) : (
                localBlogs.map((post) => (
                  <article class="post-card">
                    <div class="post-body">
                      <p class="card-meta">
                        {post.category.toUpperCase()} | {post.publishedAt.toLocaleDateString("en-US", {
                          month: "short",
                          day: "numeric",
                          year: "numeric",
                        })}
                      </p>
                      <h2 class="post-title">{post.title}</h2>
                      <p>{post.description}</p>
                      <a class="post-link" href={`/blog/${post.slug}/`} aria-label={`Read DevWire report: ${post.title}`}>Read Report</a>
                    </div>
                  </article>
                ))
              )
            }
          </section>

        </section>
      </div>
    </main>

    <Footer />
  </body>
</html>
