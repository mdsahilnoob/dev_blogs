---
export const prerender = false;

import BaseHead from "../../components/BaseHead.astro";
import BlogSidebar from "../../components/BlogSidebar.astro";
import Footer from "../../components/Footer.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import { getCategorizedEngineeringNews } from "../../lib/server/engineering-news";

const selectedCategory = Astro.url.searchParams.get("category")?.trim() || null;
const selectedSource = Astro.url.searchParams.get("source")?.trim() || null;
const searchQuery = Astro.url.searchParams.get("q")?.trim() || null;

const feedData = await getCategorizedEngineeringNews(120);

const externalPosts = feedData.items.filter((item) => {
  const categoryOk = !selectedCategory || item.category.toLowerCase() === selectedCategory.toLowerCase();
  const sourceOk = !selectedSource || item.sourceName.toLowerCase() === selectedSource.toLowerCase();
  const searchHaystack = `${item.title} ${item.contentSummary} ${item.sourceName} ${item.category}`.toLowerCase();
  const searchOk = !searchQuery || searchHaystack.includes(searchQuery.toLowerCase());
  return categoryOk && sourceOk && searchOk;
});

---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Reports | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <main id="main-content">
      <div class="blog-page-layout">
        <BlogSidebar
          categories={feedData.categories}
          searchQuery={searchQuery ?? ""}
          selectedCategory={selectedCategory}
          selectedSource={selectedSource}
        />

        <section class="blog-main">
          <section class="page-head">
            <p class="section-kicker">Engineering News Feed</p>
            <h1 class="page-title">Latest Engineering Reports</h1>
            <p class="page-sub">
              Curated daily updates from Netflix, Meta, LinkedIn, Uber, Airbnb, Discord, Cloudflare, and GitHub.
              Stories are grouped into Web Engineering, Cloud/DevOps, AI/ML, Security, Data Systems, and Infrastructure.
            </p>
            {
              (selectedCategory || selectedSource || searchQuery) && (
                <p class="card-meta" style="margin-top:10px;">
                  Active Filters:
                  {selectedCategory ? ` category=${selectedCategory}` : ""}
                  {selectedSource ? ` source=${selectedSource}` : ""}
                  {searchQuery ? ` q=${searchQuery}` : ""}
                  <a class="post-link" style="margin-left:8px;" href="/blog">Clear</a>
                </p>
              )
            }
          </section>

          <section class="post-grid">
            {
              externalPosts.length === 0 ? (
                <article class="post-card">
                  <div class="post-body">
                    <h2 class="post-title">No matching engineering posts found.</h2>
                    {
                      searchQuery && (
                        <p>
                          Try a different search for <strong>{searchQuery}</strong> or clear filters.
                        </p>
                      )
                    }
                  </div>
                </article>
              ) : (
                externalPosts.map((post) => (
                  <article class="post-card">
                    <div class="post-body">
                      <p class="card-meta">
                        {post.category.toUpperCase()} | {post.sourceName.toUpperCase()} | {post.readingTimeMinutes} MIN READ
                      </p>
                      <h2 class="post-title">{post.title}</h2>
                      <p>{post.contentSummary}</p>
                      <p class="meta-chip" style="display:block;margin-bottom:8px;">
                        {post.author ? `By ${post.author}` : "Author unavailable"} | {post.publishedAt.toLocaleDateString("en-US", {
                          month: "short",
                          day: "numeric",
                          year: "numeric",
                        })}
                      </p>
                      <a
                        class="post-link"
                        href={post.sourceUrl}
                        target="_blank"
                        rel="noreferrer"
                        aria-label={`Read original post from ${post.sourceName}: ${post.title}`}
                      >
                        Read Original
                      </a>
                    </div>
                  </article>
                ))
              )
            }
          </section>

        </section>
      </div>
    </main>

    <Footer />
  </body>
</html>
