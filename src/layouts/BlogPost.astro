---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE } from "../consts";

type Props = {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  readingTimeMinutes?: number;
  heroImage?: ImageMetadata;
  tags?: string[];
  category?: string;
  draft?: boolean;
};

const { title, description, pubDate, updatedDate, readingTimeMinutes, heroImage, category } = Astro.props;

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).toString(),
  image: heroImage ? new URL(heroImage.src, Astro.url).toString() : undefined,
};
---

<html lang="en">
  <head>
    <BaseHead
      title={`${title} | ${SITE_TITLE}`}
      description={description}
      type="article"
      image={heroImage}
      publishedTime={pubDate}
      modifiedTime={updatedDate ?? pubDate}
      jsonLd={articleJsonLd}
    />
  </head>

  <body>
    <main id="main-content">
      <div class="container">
        <article class="article-shell">
          <header class="article-lead">
            <p class="section-kicker">{(category ?? "Engineering").toUpperCase()}</p>
            <h1>{title}</h1>
            <p style="margin:0;color:#444;">{description}</p>
            <p class="card-meta" style="margin-top:8px;">
              Published {pubDate.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}
              {` | ${readingTimeMinutes ?? 1} min read`}
              {updatedDate ? ` | Updated ${updatedDate.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}` : ""}
            </p>
          </header>

          <section class="article-prose">
            {
              heroImage && (
                <div style="margin-bottom:16px;">
                  <Image width={1020} height={510} src={heroImage} alt={`Cover image for ${title}`} />
                </div>
              )
            }
            <slot />
          </section>
        </article>
      </div>
    </main>

    <Footer />
  </body>
</html>
